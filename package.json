{
    "name": "stock-prices",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "bun build ./src/main.ts --compile --outfile ./dist/main --external @nestjs/microservices --external @nestjs/websockets --external @nestjs/websockets/socket-module --external class-transformer --external class-validator",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start:dev": "bun --watch ./src/main.ts",
        "start:debug": "bun --inspect --watch ./src/main.ts",
        "start:prod": "./dist/main",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@nestjs/common": "11.1.19",
        "@nestjs/core": "11.1.19",
        "@nestjs/platform-express": "11.1.19",
        "@toon-format/toon": "2.1.0",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "yahoo-finance2": "3.14.0"
    },
    "devDependencies": {
        "@nestjs/cli": "11.0.21",
        "@nestjs/testing": "11.1.19",
        "@types/bun": "^1.3.13",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/supertest": "7.2.0",
        "jest": "30.3.0",
        "prettier": "3.8.3",
        "supertest": "7.2.2",
        "ts-jest": "29.4.9",
        "ts-node": "10.9.2",
        "typescript": "6.0.3"
    }
}
